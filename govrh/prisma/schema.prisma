model Dependente {
  id                String         @id @default(uuid())
  servidorId        String
  nome              String         @db.VarChar(150)
  cpf               String?        @db.VarChar(14)
  dataNascimento    DateTime       @db.Date
  tipoDependente    TipoDependente
